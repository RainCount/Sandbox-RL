# 复制为 .env；严禁提交真实值。应用只从环境变量读取密钥。
E2B_DOMAIN=ap-shanghai.tencentags.com
E2B_API_KEY=
AGS_TEMPLATE=swe-rl-sandbox
AGS_TIMEOUT_SECONDS=1800
AGS_MAX_CONCURRENCY=20
DOCKERHUB_MIRROR=https://mirror.ccs.tencentyun.com
# 逗号分隔；只在 TCR 和腾讯云 Registry mirror 都失败时使用。
DOCKERHUB_FALLBACK_PREFIXES=docker.1ms.run

TCR_REGISTRY=example.tencentcloudcr.com
TCR_NAMESPACE=swe-rl
TCR_USERNAME=
TCR_PASSWORD=

COS_REGION=ap-shanghai
COS_BUCKET=example-1250000000
COS_PREFIX=swe-rl
COS_SECRET_ID=
COS_SECRET_KEY=
COS_TOKEN=

WANDB_API_KEY=
WANDB_PROJECT=swe-rl

# 训练 Job 内的路径；基础模型由 initContainer 下载到这里。
MODEL_PATH=/workspace/runtime/model
RUN_ID=local-dev
ROUND_ID=0
TRACE_DIR=/workspace/runtime/traces
